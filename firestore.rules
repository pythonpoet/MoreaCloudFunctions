rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /config/{document=**} {
      allow read;
      allow write: if false;
    }
    match /user/{document}{
    	allow read;
    	allow write, delete, update, create: if request.auth.uid == document;
      allow write, delete, update, create: if request.auth.uid in resource.data.Eltern;
      allow write, delete, update, create: if request.auth.uid in resource.data.Kinder;
      allow write, delete, update, create: if get(/databases/$(database)/documents/user/$(request.auth.uid)).data.roleID > 0;
    }
    match /groups/{document=**}{
    	allow read, write, delete, update;
    }
  }
}